@startuml
title 图3：召回-粗排-精排-重排流程
skinparam shadowing false

"全量候选集" --> "多路召回"
"多路召回" --> "协同过滤召回"
"多路召回" --> "语义召回"
"多路召回" --> "热门召回"
"多路召回" --> "本地召回"
"协同过滤召回" --> "召回结果"
"语义召回" --> "召回结果"
"热门召回" --> "召回结果"
"本地召回" --> "召回结果"
"召回结果" --> "轻量级模型"
"轻量级模型" --> "快速筛选"
"快速筛选" --> "粗排结果"
"粗排结果" --> "深度模型"
"深度模型" --> "精细打分"
"精细打分" --> "精排结果"
"精排结果" --> "多样性处理"
"多样性处理" --> "业务规则"
"业务规则" --> "最终结果"
@enduml
