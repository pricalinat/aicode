@startuml
title 图1：搜索匹配流程图
skinparam shadowing false

"用户Query" --> "Query分析"
"Query分析" --> "特征提取"
"特征提取" --> "意图识别"
"意图识别" --> "词项匹配"
"意图识别" --> "语义匹配"
"意图识别" --> "向量匹配"
"词项匹配" --> "结果合并"
"语义匹配" --> "结果合并"
"向量匹配" --> "结果合并"
"结果合并" --> "相关性排序"
"相关性排序" --> "质量分数"
"质量分数" --> "商业因子"
"商业因子" --> "最终排序"
"最终排序" --> "结果去重"
"结果去重" --> "多样性处理"
"多样性处理" --> "展示排序"
@enduml
