@startuml
title 图5：用户意图理解流程
skinparam shadowing false

"用户Query" --> "用户画像"
"用户画像" --> "Query解析"
"Query解析" --> "意图分类"
"意图分类" --> "意图扩展"
"意图扩展" --> "文本特征"
"意图扩展" --> "行为特征"
"意图扩展" --> "上下文特征"
"文本特征" --> "特征融合"
"行为特征" --> "特征融合"
"上下文特征" --> "特征融合"
"特征融合" --> "搜索匹配"
"特征融合" --> "推荐匹配"
"搜索匹配" --> "结果选择"
"推荐匹配" --> "结果选择"
"结果选择" --> "置信度判断"
"置信度判断" --> "服务路由"
"服务路由" --> "最终响应"
@enduml
