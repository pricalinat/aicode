skinparam shadowing false

"位置偏差" --> "首位效应"
"位置偏差" --> "末尾效应"
"熟悉度偏差" --> "模型偏好"
"熟悉度偏差" --> "风格偏差"
"顺序偏差" --> "选项位置"
"首位效应" --> "AB测试"
"末尾效应" --> "AB测试"
"模型偏好" --> "对比分析"
"风格偏差" --> "对比分析"
"选项位置" --> "位置交换"
"AB测试" --> "加权平均"
"对比分析" --> "去偏模型"
"位置交换" --> "位置消融"
"加权平均" --> "人工评估"
"去偏模型" --> "人工评估"
"位置消融" --> "人工评估"
"人工评估" --> "偏差降低"
