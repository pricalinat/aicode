@startuml
title 图1：服务理解系统架构
skinparam shadowing false

"用户Query" --> "语音/文本输入"
"语音/文本输入" --> "预处理模块"
"预处理模块" --> "意图识别器"
"意图识别器" --> "槽位提取"
"槽位提取" --> "实体识别"
"意图识别器" --> "语义理解引擎"
"槽位提取" --> "语义理解引擎"
"实体识别" --> "语义理解引擎"
"语义理解引擎" --> "服务匹配器"
"服务匹配器" --> "服务知识图谱"
"服务知识图谱" --> "服务目录"
"服务知识图谱" --> "业务规则库"
"服务知识图谱" --> "FAQ知识库"
"服务匹配器" --> "服务编排引擎"
"服务目录" --> "服务编排引擎"
"业务规则库" --> "服务编排引擎"
"服务编排引擎" --> "API网关"
"API网关" --> "后端服务"
"后端服务" --> "结果聚合"
"结果聚合" --> "结果生成"
"结果生成" --> "多模态输出"
"多模态输出" --> "用户反馈"
"用户反馈" --> "意图识别器": 循环优化
@enduml
