@startuml
title 图3：A/B测试流程图
skinparam shadowing false

"假设提出" --> "样本量计算"
"样本量计算" --> "流量分配"
"流量分配" --> "实验分组"
"实验分组" --> "版本A对照组"
"实验分组" --> "版本B实验组"
"版本A对照组" --> "数据收集"
"版本B实验组" --> "数据收集"
"数据收集" --> "显著性检验"
"显著性检验" --> "效果量计算"
"效果量计算" --> "置信区间"
"置信区间" --> "全量发布"
"置信区间" --> "继续测试"
"置信区间" --> "回滚版本"
"全量发布" --> "性能监控"
"继续测试" --> "性能监控"
"性能监控" --> "异常告警"
"异常告警" --> "自动回滚"
@enduml
